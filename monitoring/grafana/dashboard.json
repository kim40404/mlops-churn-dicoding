{
  "title": "MLOps Churn Monitoring",
  "uid": "mlops-churn-dashboard",
  "panels": [
    {
      "type": "stat",
      "title": "Total Prediction Requests",
      "targets": [
        {
          "expr": "prediction_requests_total",
          "datasource": "Prometheus"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      }
    },
    {
      "type": "graph",
      "title": "Prediction Latency (seconds)",
      "targets": [
        {
          "expr": "rate(prediction_latency_seconds_sum[1m]) / rate(prediction_latency_seconds_count[1m])",
          "datasource": "Prometheus"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      }
    }
  ],
  "schemaVersion": 38,
  "timezone": "browser",
  "refresh": "5s"
}
